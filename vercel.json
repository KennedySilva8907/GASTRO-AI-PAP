{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/chatbot", "dest": "/public/chat/chatbot.html" },
    { "src": "/desafios", "dest": "/public/challenges/desafio.html" },
    { "src": "/receitas", "dest": "/public/recipes/receitas.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
