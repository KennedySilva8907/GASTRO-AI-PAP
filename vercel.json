{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/chat", "dest": "/chat/chatbot.html" },
    { "src": "/challenges", "dest": "/challenges/desafio.html" },
    { "src": "/recipes", "dest": "/recipes/receitas.html" }
  ]
}
