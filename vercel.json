{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/cron/keepalive",
      "schedule": "0 12 * * *"
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/chat", "destination": "/chat/chatbot.html" },
    { "source": "/challenges", "destination": "/challenges/desafio.html" },
    { "source": "/recipes", "destination": "/recipes/receitas.html" },
    { "source": "/recipes/([a-z0-9-]+)", "destination": "/recipes/receitas.html?recipe=$1" },
    { "source": "/auth/login", "destination": "/auth/login.html" },
    { "source": "/auth/register", "destination": "/auth/register.html" },
    { "source": "/auth/forgot-password", "destination": "/auth/forgot-password.html" },
    { "source": "/auth/reset-password", "destination": "/auth/reset-password.html" },
    { "source": "/auth/callback", "destination": "/auth/callback.html" },
    { "source": "/auth/account", "destination": "/auth/account.html" },
    { "source": "/auth", "destination": "/auth/login.html" },
    { "source": "/billing", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://pham.codes; img-src 'self' data: blob: https://cdn-icons-png.flaticon.com https://lh3.googleusercontent.com https://*.supabase.co https://asset.skoiy.com https://cdn.shopify.com https://www.pingodoce.pt https://assets.epicurious.com https://assets.bonappetit.com https://www.biltmore.com https://assets.vogue.com https://img.taste.com.au https://images.pexels.com https://media-assets.lacucinaitaliana.it; connect-src 'self' https://*.supabase.co https://api.groq.com https://esm.sh https://cdn.jsdelivr.net; frame-src https://www.youtube.com https://*.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self' https://*.stripe.com; frame-ancestors 'self' https://portfolio-kennedy-silva.vercel.app http://localhost:3000"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/auth/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*\\.svg|.*\\.png|.*\\.jpg|.*\\.webp)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
